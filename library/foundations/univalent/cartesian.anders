module cartesian where
import library/foundations/univalent/path

--- AFH, ABCFHL

def coei‚Üí0  (A : I ‚Üí U) (i : I) (a : A i) : A 0 := transp (<j> A (i ‚àß -j)) (-i) a
def coe1‚Üíi  (A : I ‚Üí U) (i : I) (a : A 1) : A i := transp (<j> A (i ‚à® -j)) i a
def coe0‚Üíi  (A : I ‚Üí U) (r : I) (a : A 0) : A r := transp (<j> A (r ‚àß j)) (-r) a
def coe0‚Üí1  (A : I ‚Üí U) (a : A 0) : A 1 := transp (<i> A i) 0 a
def coe1‚Üí0  (A : I ‚Üí U) (a : A 1) : A 0 := transp (<i> A (-i)) 0 a
def coe0‚Üíi0 (A : I ‚Üí U) (a : A 0) : Path (A 0) (coe0‚Üíi A 0 a) a := <_> a
def coei0‚Üí0 (A : I ‚Üí U) (a : A 0) : Path (A 0) (coei‚Üí0 A 0 a) a := <_> a
def coei1‚Üí0 (A : I ‚Üí U) (a : A 1) : Path (A 0) (coei‚Üí0 A 1 a) (coe1‚Üí0 A a) := <_> (coe1‚Üí0 A a)
def coe0‚Üíi1 (A : I ‚Üí U) (a : A 0) : Path (A 1) (coe0‚Üíi A 1 a) (coe0‚Üí1 A a) := <_> (coe0‚Üí1 A a)
